{ // @author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.untrustedFiles": "open",
  "explorer.confirmDelete": false,

  "window.commandCenter": true,
  "window.menuBarVisibility": "compact",

  "java.configuration.runtimes": [
    {
      "name": "JavaSE-20",
      "path": "/usr/bin/java",
      "default": true
    }
  ],

  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",

  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.clearPreviousOutput": false,
  "code-runner.preserveFocus": false,
  "code-runner.cwd": "/home/jr3/workspace/build",
  "code-runner.temporaryFileName": "tempErrorFile",
  "code-runner.executorMap": {
    "cpp": "clear && cd $dir && g++ $fileName -o /home/jr3/workspace/build/vs-sol.exe -std=c++17 -march=native -Wall -Wextra -Wshadow -Wvla -Djosuerom && /home/jr3/workspace/build/vs-sol.exe",
    "java": "clear && cd $dir && javac -d /home/jr3/workspace/build $fileName && cd /home/jr3/workspace/build && java -Xmx512M -Xss64M -XX:+UseG1GC -DLOCAL=1 $fileNameWithoutExt",
    "run java": "clear && cd ~/workspace/build && java -Xmx512M -Xss64M -XX:+UseG1GC -DLOCAL=1 $fileNameWithoutExt",
    "run cpp": "clear && /home/jr3/workspace/build/vs-sol.exe",

    "python": "clear && cd $dir && python -OO -S -B $fileName",
    "javascript": "clear && cd $dir && node $fileName",
    "typescript": "clear && cd $dir && node $fileName",
  },

  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "fluent-icons",
  // "workbench.activityBar.visible": false,
  // "workbench.statusBar.visible": false,
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": false,

  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontSize": 15.4,
  "editor.fontWeight": "100",
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "debug.onTaskErrors": "debugAnyway",
  "breadcrumbs.enabled": false,

  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",

  "catalyst.default.layoutRatio": 55,
  "catalyst.default.saveLocation": "/home/jr3/workspace/build",
  "catalyst.default.theme": "Dark",
  "catalyst.lang.cpp.args": "-std=c++17 -march=native -Wall -Wextra -Wshadow -Wvla -Djosuerom",
  "catalyst.lang.java.runtime.args": "-Xmx512M -Xss64M -XX:+UseG1GC -DLOCAL=1",
  "catalyst.lang.python.args": "-OO -S -B",

  "cph.general.menuChoices": "cpp java python",
  "cph.general.timeOut": 3000,
  "cph.general.ignoreSTDERROR": true,
  "cph.language.java.SubmissionCompiler": "Java 1.8.0_241",
  "cph.language.python.SubmissionCompiler": "Python 3.7.2",
  "cph.general.saveLocation": "/home/jr3/workspace/build",
  "cph.language.cpp.Args": "-march=native -Wall -Wextra -Wshadow -Wvla -Djosuerom",
  "cph.language.java.Args": "-Xmx512M -Xss64M -XX:+UseG1GC -DLOCAL=1",
  "cph.language.python.Args": "-OO -S -B",
}
