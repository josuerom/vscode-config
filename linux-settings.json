{ // @author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "explorer.confirmDelete": false,
  "redhat.telemetry.enabled": false,
  "window.commandCenter": true,
  "window.menuBarVisibility": "compact",
  "window.zoomLevel": 1,
  "[java]": {
    // "editor.formatOnSave": true,
    // "editor.formatOnPaste": true,
    // "editor.defaultFormatter": "redhat.java"
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontFamily": "JetBrains Mono",
  "terminal.integrated.fontSize": 14.2,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.showRunCommandInEditorContextMenu": false,
  "code-runner.clearPreviousOutput": true,
  "code-runner.preserveFocus": false,
  "code-runner.cwd": "/home/josuerom/Workspace/bin",
  "code-runner.executorMap": {
    // BUILD & RUN PROGRAM CODEFORCES C++17 INPUT MANUAL
    "cpp": "clear && cd $dir && g++ $fileName -o ~/Workspace/bin/sol -std=c++17 -Wall -Wno-sign-conversion -DLOCAL && ~/Workspace/bin/sol",
    // BUILD & RUN PROGRAM CODEFORCES C++17 FROM INPUT FILE
    // "cpp": "clear && cd $dir && g++ $fileName -o ~/Workspace/bin/sol -std=c++17 -Wall -Wno-sign-conversion -DLOCAL && ~/Workspace/bin/sol < samples/in1",
    // BUILD & RUN PROGRAM C++20 OFF CONSOLE & RESULT IN FILE OUTPUT
    // "cpp": "clear && cd $dir && g++ $fileName -o ~/Workspace/bin/sol -std=c++20 -Wall -Wno-sign-conversion -DLOCAL && ~/Workspace/bin/sol < samples/in1 > samples/output",
    // RPC C++11 FROM INPUT FILE
    // "cpp": "clear && cd $dir && g++ $fileName -o $fileNameWithoutExt -std=c++11 -O2 -Wall -DLOCAL && $fileNameWithoutExt < in1",
    // REPEAT EXECUTE WITH MANUAL INPUT
    "run_cpp": "clear && ~/Workspace/bin/sol",

    // BUILD & RUN JAVA > 8 INPUT MANUAL
    "java": "clear && cd $dir && java $fileName",
    // BUILD & RUN FOR JAVA = 8
    // "java": "clear && cd $dir && javac -d ~/Workspace/bin $fileName && java -cp ~/Workspace/bin $fileNameWithoutExt",
    // REPEAT EXECUTE FILE .class
    // "java": "clear && java -cp ~/Workspace/bin $fileNameWithoutExt",

    "python": "clear && cd $dir && python3 -OO -S -B $fileName",
    "javascript": "clear && cd $dir && node $fileName",
    "typescript": "clear && cd $dir && node $fileName",
  },
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "single",
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "editor.accessibilitySupport": "off",
  "editor.hover.sticky": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "update.showReleaseNotes": false,
  "notebook.formatOnSave.enabled": true,
  "workbench.editor.labelFormat": "short",
  "cph.general.menuChoices": "cpp java python",
  "cph.general.saveLocation": "/home/josuerom/Workspace/bin",
  "cph.language.cpp.Args": "-std=c++17 -DONLINE_JUDGE",
  "cph.language.cpp.SubmissionCompiler": "GNU G++17 9.2.0 (64 bit, msys 2)",
  "cph.language.java.SubmissionCompiler": "Java 1.8.0_241",
  "cph.language.python.SubmissionCompiler": "PyPy 3.9.10 (7.3.9, 64bit)",
  "cph.general.timeOut": 1000,
  "cph.general.autoShowJudge": false,
  "symbols.hidesExplorerArrows": false,
  "workbench.iconTheme": "symbols",
  "workbench.productIconTheme": "fluent-icons",
  "editor.rulers": [
    90
  ],
  "security.workspace.trust.untrustedFiles": "open"
}
