{ // @author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.untrustedFiles": "open",
  "explorer.confirmDelete": false,
  "redhat.telemetry.enabled": false,

  "window.commandCenter": true,
  "window.menuBarVisibility": "compact",
  "window.zoomLevel": 1.3,

  "java.configuration.runtimes": [
    {
      "name": "JavaSE-11",
      "path": "/usr/lib/jvm/java-11-openjdk-11.0.20.0.8-1.fc38.x86_64/",
      "default": true
    }
  ],
  "[java]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "redhat.java"
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 14.85,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.showRunCommandInEditorContextMenu": false,
  "code-runner.clearPreviousOutput": true,
  "code-runner.preserveFocus": false,
  "code-runner.cwd": "/home/josuerom/workspace/bin",
  "code-runner.executorMap": {
    // BUILD & RUN PROGRAM CODEFORCES C++17 INPUT MANUAL
    "cpp": "clear && cd $dir && g++ $fileName -o ~/workspace/bin/sol.out -std=c++17 -Wall -Wno-sign-conversion -DDEBUG -DLOCAL && ~/workspace/bin/sol.out",
    // BUILD & RUN PROGRAM CODEFORCES C++17 INPUT FILE
    // "cpp": "clear && cd $dir && g++ $fileName -o ~/workspace/bin/sol.out -std=c++17 -Wall -Wno-sign-conversion -DDEBUG -DLOCAL && ~/workspace/bin/sol.out < samples\in1",
    // BUILD & RUN PROGRAM C++20 OFF CONSOLE & INPUT
    // "cpp": "clear && cd $dir && g++ $fileName -o ~/workspace/bin/sol.out -std=c++20 -Wall -Wno-sign-conversion -DDEBUG -DLOCAL && ~/workspace/bin/sol.out < samples\in1 > samples\output",
    // BUILD & RUN PROGRAM RPC C++11 INPUT FILE
    // "cpp": "clear && cd $dir && g++ $fileName -o $fileNameWithoutExt.out -std=c++11 -Wall -lm -lcrypt -fno-asm -pedantic -Wno-sign-conversion -DDEBUG -DLOCAL && $fileNameWithoutExt.out < in1",
    // REPEAT EXECUTE FILE.exe
    "run_cpp": "clear && ~/workspace/bin/sol.out",

    // FOR JAVA > 8
    "java": "clear && cd $dir && java $fileName",
    // FOR JAVA 8
    // "java": "clear && cd $dir && javac -d ~/workspace/bin $fileName && java -cp ~/workspace/bin $fileNameWithoutExt",
    // REPEAT EXECUTE FILE .class
    // "java": "clear && java -cp ~/workspace/bin $fileNameWithoutExt",

    "python": "clear && cd $dir && python -OO -S -B $fileName",
    "javascript": "clear && cd $dir && node $fileName",
    "typescript": "clear && cd $dir && node $fileName",
  },
  "workbench.colorTheme": "Default Dark Modern",
  // "workbench.colorTheme": "Monokai",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.sideBar.location": "right",
  "workbench.statusBar.visible": true,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "single",
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontSize": 14.5,
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "editor.accessibilitySupport": "off",
  "editor.hover.sticky": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "update.showReleaseNotes": false,
  "notebook.formatOnSave.enabled": true,
  "workbench.editor.labelFormat": "short",
  "cph.general.menuChoices": "cpp java",
  "cph.general.saveLocation": "/home/josuerom/workspace/bin",
  "cph.language.cpp.Args": "-std=c++17 -Wall -Wno-sign-conversion -DONLINE_JUDGE",
  // "cph.language.cpp.Args": "-std=c++11 -lm -lcrypt -fno-asm -s -DONLINE_JUDGE",
  "cph.general.timeOut": 1000,
  "cph.general.autoShowJudge": false,
  "trailing-spaces.trimOnSave": true,
}
