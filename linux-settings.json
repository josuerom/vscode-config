{ //@author: josuerom
  "workbench.iconTheme": "material-icon-theme",
  "editor.fontFamily": "'JetBrains Mono', 'UbuntuMono NF', monospace",
  "terminal.integrated.gpuAcceleration": "off",
  "security.workspace.trust.untrustedFiles": "open",
  "editor.fontSize": 15.2,
  "editor.fontWeight": "370",
  "extensions.ignoreRecommendations": true,
  "workbench.editor.enablePreview": false,
  "editor.fontLigatures": true,
  "workbench.startupEditor": "none",
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "files.autoSave": "onFocusChange",
  "editor.wordWrap": "on",
  "diffEditor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "workbench.layoutControl.enabled": false,
  "window.menuBarVisibility": "compact",
  "editor.suggestSelection": "first",
  "terminal.integrated.cursorStyle": "line",
  "debug.terminal.clearBeforeReusing": true,
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontFamily": "'Cascadia Code'",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.executorMap": {
    "cpp": "clear && cd $dir && g++ $fileName -o ~/workspace/build/sol.out -Wall -Wextra -Wshadow -Wpedantic -Weffc++ -Wvla -Djosuerom",
    "java": "clear && cd $dir && javac -d ~/workspace/build $fileName",
    "sol.out": "clear && ~/workspace/build/sol.out",
    "sol.class": "clear && cd ~/workspace/build && java $fileNameWithoutExt",
    "python": "clear && cd $dir && python3 $fileName",
    "javascript": "node $dir/$fileName",
    "typescript": "node $dir/$fileName"
  },
  "code-runner.temporaryFileName": "fileTempError",
  "explorer.confirmDelete": false,
  //"workbench.statusBar.visible": false,
  //"workbench.activityBar.visible": false,
  "window.commandCenter": true,
  "workbench.sideBar.location": "right",
  "workbench.editor.showTabs": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "debug.onTaskErrors": "debugAnyway",
  "breadcrumbs.enabled": false,
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-19",
      "path": "usr/lib/jvm/java-19-openjdk-amd64/",
      "default": true
    }
  ],
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "redhat.telemetry.enabled": false,
  "git.openRepositoryInParentFolders": "never",
  "editor.formatOnPaste": true,
  // settigns cph submit for codeforces
  "cph.general.menuChoices": "cpp java",
  "cph.general.timeOut": 1000,
  "cph.language.cpp.SubmissionCompiler": "GNU G++20 11.2.0 (64 bit, winlibs)",
  "cph.language.java.SubmissionCompiler": "Java 1.8.0_241",
  "cph.language.cpp.Args": "-std=c++20 -Wall -Wextra -Wshadow -Wpedantic -Djosuerom -Wconversion -Wvla -ggdb3 -D_GLIBCXX_DEBUG -D_GLIBCXX_DEBUG_PEDANTIC",
  "code-runner.defaultLanguage": "cpp java",
}
