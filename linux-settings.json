{ // @author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "explorer.confirmDelete": false,
  "redhat.telemetry.enabled": false,
  "window.commandCenter": true,
  "window.zoomLevel": 1,
  "[java]": {
    // "editor.formatOnSave": true,
    // "editor.formatOnPaste": true,
    // "editor.defaultFormatter": "redhat.java"
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontFamily": "JetBrains Mono",
  "terminal.integrated.fontSize": 14.2,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.showRunCommandInEditorContextMenu": false,
  "code-runner.clearPreviousOutput": true,
  "code-runner.preserveFocus": false,
  "code-runner.cwd": "/home/josuerom/Workspace/bin",
  "code-runner.executorMap": {
    // compile and execute C++17 program, with manual entry
    "cpp": "clear && cd $dir && g++ $fileName -o ~/Workspace/bin/sol -std=c++17 -O2 -DLOCAL && ~/Workspace/bin/sol",

    // // compile and execute C++17 program, with input per file
    // "cpp": "clear && cd $dir && g++ $fileName -o ~/Workspace/bin/sol -std=c++17 -O2 -DLOCAL && ~/Workspace/bin/sol < ../samples/in1",

    // // compile and execute C++20 program, with input per file and output per file
    // "cpp": "clear && cd $dir && g++ $fileName -o ~/Workspace/bin/sol -std=c++20 -O2 -DLOCAL && ~/Workspace/bin/sol < ../samples/input.in > ../samples/output.out",

    // // compile and run C++11 program for RPC, with input per file
    // "cpp": "clear && cd $dir && g++ $fileName -o $fileNameWithoutExt -std=c++11 -O2 -DLOCAL && ./$fileNameWithoutExt < in1",
    
    // // compile and run java version = 8 program, with manual entry
    // "java": "clear && cd $dir && javac -d ~/Workspace/bin $fileName && java -cp ~/Workspace/bin $fileNameWithoutExt",
    // "rep_java": "clear && java -cp ~/Workspace/bin $fileNameWithoutExt",

    // compile and run java programs versions greater than > 8, with manual entry
    "java": "clear && cd $dir && java $fileName",
    "rep_java": "clear && cd $dir && java $fileName < ../samples/in1",
  
    "rep_cpp": "clear && ~/Workspace/bin/sol",

    "python": "clear && cd $dir && python3 -OO -S -B $fileName",
    "javascript": "clear && cd $dir && node $fileName",
    "typescript": "clear && cd $dir && node $fileName",
  },
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "symbols",
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "single",
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "editor.accessibilitySupport": "off",
  "editor.hover.sticky": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "update.showReleaseNotes": false,
  "notebook.formatOnSave.enabled": true,
  "workbench.editor.labelFormat": "short",
  "cph.general.menuChoices": "cpp java python",
  "cph.general.saveLocation": "/home/josuerom/Workspace/bin",
  "cph.general.timeOut": 1100,
  "cph.general.autoShowJudge": false,
  "symbols.hidesExplorerArrows": false,
  "editor.rulers": [90],
  "cppref.lang": "es",
  "cppref.searchEngine": "Google"
}
