{ // @author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.untrustedFiles": "open",
  "explorer.confirmDelete": false,
  "redhat.telemetry.enabled": false,

  "window.commandCenter": true,
  "window.menuBarVisibility": "compact",
  "window.zoomLevel": 1,

  "java.configuration.runtimes": [
    {
      "name": "JavaSE-11",
      "path": "/usr/lib/jvm/java-11-openjdk-amd64/",
      "default": true
    }
  ],
  "[java]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "redhat.java"
  },
  "[python]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "ms-python.autopep8",
  },
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.fontFamily": "JetBrains Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.showRunCommandInEditorContextMenu": false,
  "code-runner.clearPreviousOutput": true,
  "code-runner.preserveFocus": false,
  "code-runner.cwd": "/home/jr3/workspace/build",
  "code-runner.temporaryFileName": "tempErrorFile",
  "code-runner.executorMap": {
    "cpp": "clear && cd $dir && g++ $fileName -o /home/jr3/workspace/build/vs-sol.out -std=c++17 -march=native -Wall -Wextra -Wshadow -Wvla -Djosuerom -D_2BITS && /home/jr3/workspace/build/vs-sol.out",
    "java": "clear && cd $dir && javac -d /home/jr3/workspace/build $fileName && cd /home/jr3/workspace/build && java $fileNameWithoutExt",
    "run java": "clear && cd ~/workspace/build && java $fileNameWithoutExt",
    "run cpp": "clear && /home/jr3/workspace/build/vs-sol.out",
    "python": "clear && cd $dir && python -OO -S -B $fileName",
    "javascript": "clear && cd $dir && node $fileName",
    "typescript": "clear && cd $dir && node $fileName",
    "workbench.colorTheme": "Default Dark Modern",
  },
  // "workbench.colorTheme": "Monokai",
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.sideBar.location": "right",
  "workbench.statusBar.visible": true,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": false,
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "editor.accessibilitySupport": "off",
  "editor.hover.sticky": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "cph.general.menuChoices": "cpp java python",
  "cph.general.saveLocation": "/home/jr3/workspace/build",
  "cph.language.cpp.Args": "-Wall -Wextra -Wvla",
  "cph.language.python.Args": "-OO -S -B",
  "cph.general.timeOut": 1000,
  "python.formatting.provider": "none",
  "update.showReleaseNotes": false,
  "notebook.formatOnSave.enabled": true,
  "workbench.editor.labelFormat": "short",
  "C_Cpp.autocompleteAddParentheses": true,
  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.clang_format_sortIncludes": true,
  "C_Cpp.formatting": "clangFormat",
}
