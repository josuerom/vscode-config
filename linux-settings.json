{ //@author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.untrustedFiles": "open",
  "redhat.telemetry.enabled": false,
  "explorer.confirmDelete": false,

  "window.commandCenter": true,
  "window.menuBarVisibility": "compact",

  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },

  "java.configuration.runtimes": [
    {
      "name": "JavaSE-19",
      "path": "usr/lib/jvm/java-19-openjdk-amd64/",
      "default": true
    }
  ],

  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontFamily": "'Cascadia Code'",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",

  "code-runner.temporaryFileName": "fileTempError",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.clearPreviousOutput": true,
  "code-runner.defaultLanguage": "cpp java",
  "code-runner.fileDirectoryAsCwd": true,
  "code-runner.executorMap": {
    "cpp": "clear && cd $dir && g++ $fileName -o ~/workspace/build/sol.out -Wall -Wextra -Wshadow -Wpedantic -Weffc++ -Wvla -Djosuerom",
    "java": "clear && cd $dir && javac -d ~/workspace/build $fileName",
    "run c++": "clear && ~/workspace/build/sol.out",
    "run java": "clear && cd ~/workspace/build && java -Xmx512M -Xss64M -DONLINE_JUDGE=true $fileNameWithoutExt",
    "open input file": "clear && gedit ~/workspace/sample/input &",
    "python": "clear && cd $dir && python3 $fileName",
    "javascript": "node $dir/$fileName",
    "typescript": "node $dir/$fileName"
  },

  // "workbench.statusBar.visible": false,
  // "workbench.activityBar.visible": false,
  "workbench.colorTheme": "Palenight Operator",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": false,

  "editor.fontFamily": "'JetBrains Mono', 'UbuntuMono Nerd Font'",
  "editor.fontSize": 15.2,
  "editor.fontWeight": "370",
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "debug.onTaskErrors": "debugAnyway",
  "breadcrumbs.enabled": false,

  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",

  "cph.general.menuChoices": "cpp java",
  "cph.language.cpp.SubmissionCompiler": "GNU G++17 7.3.0",
  "cph.language.java.SubmissionCompiler": "Java 1.8.0_241",
  "cph.general.saveLocation": "~/workspace/build",
  "cph.general.timeOut": 3000,
  // "cph.general.defaultLanguageTemplateFileLocation": "~/workspace/templates/tem.java",
  "cph.language.cpp.Args": "-march=native -Wall -Wextra -Wpedantic -Wshadow -Wvla -Djosuerom",
  "cph.language.java.Args": "-Xmx512M -Xss64M -DONLINE_JUDGE=true",
}
