{
	"#ifdef ONLINE_JUDGE": {
		"prefix": "ifdef",
		"body": [
			"#ifndef ONLINE_JUDGE",
      	"\tfreopen(\"TEST/input.in\", \"r\", stdin);",
      	"\tfreopen(\"TEST/output.ans\", \"w\", stdout);",
   		"#endif"
		]
	},

	"ios::sync_with_stdio(false)": {
		"prefix": "ios",
		"body": [
			"ios::sync_with_stdio(false); cin.tie(nullptr); cout.tie(nullptr);"
		]
	},

	"using namespace std": {
		"prefix": "using",
		"body": [
			"using namespace std;"
		]
	},

	"return": {
		"prefix": "re",
		"body": [
			"return$1;"
		]
	},

	"for (int i = 0; i < vec.size(); i++)": {
		"prefix": "fori",
		"body": [
			"for (int ${1:i} = 0; ${1:i} < ${2:vec.size()}; ${1:i}++) {",
			"}",
		]
	},

	"for (auto $e : vec)": {
		"prefix": "fore",
		"body": [
			"for (auto &e : ${vector}) {",
			"}",
		]
	},

	"#include <bits/stdc++.h>": {
		"prefix": "inc",
		"body": [
			"#include <bits/stdc++.h>"
		]
	},

	"Plantilla c++ para competencias": {
		"prefix": "cpp_template_to_compete",
		"body": [
			"/*",
			" * @solution implemented for the problem: ${1:problemName}",
			" * @author josuerom",
			"*/",
			"//#pragma GCC optimize(\"03,unroll-loops\")",
			"#include <bits/stdc++.h>\n",
			"#define fastIO() ios::sync_with_stdio(false); cin.tie(0);",
			"#define all(vec) vec.begin(), vec.end()",
			"#define rall(vec) vec.rbegin(), vec.rend()",
			"#define decimals(n) cout.setf(ios::fixed, ios::floatfield); cout.precision(n);",
			"#define sort(vec) sort(vec.begin(), vec.end())",
			"#define sortreverse(vec) reverse(vec.begin(), vec.end())",
			"#define fori(a, b, c) for(int (a) = (b); (a)<(c); (a)++)",
			"#define fore(e, vec) for (auto &(e): (vec))",
			"#define forr(i, vec) for(int i = (int)(vec).size()-1; i >= 0; i--)",
			"#define size(vec) (int)(vec.size())",
			"#define module(a, b, mod) ((((a) % (mod)) + ((b) % (mod))) % (mod))",
			"#define binarysearch(vec, key) sort(all(vec)); binary_search(all(vec), key);",
			"#define mcd(a, b) gcd(a, b)",
			"#define isordered(vec) is_heap(all(vec))",
			"#define read_array(vec) void template<typename T> void read(vector<T>& (vec)) { int n=(vec).size(); for(int i = 0; i < n; i++) { cin >> (vec)[i]; } }",
			"#define length(vec) sizeof(vec)/sizeof(vec[0])",
			"",
			"using namespace std;",
			"typedef unsigned long long int ull; //18^19",
			"typedef long long int ll; //9^18",
			"typedef unsigned int ui; //4^9",
			"typedef unsigned short int us; //65^3",
			"",
			"void solve() {$4",
			"\t$2",
			"}",
			"",
			"int main() {",
			"\tfastIO();",
			"\t#ifdef LOCAL",
			"\t\tfreopen(\".in\", \"r\", stdin);",
			"\t\tfreopen(\".out\", \"w\", stdout);",
			"\t#endif\n",
			"\t${3:us} t=0;",
			"\tcin >> t;",
			"\twhile (t--) { solve(); }",
			"\treturn 0;",
			"}",
		],
		"description": "Plantilla de C++ para competencias"
	}
}
