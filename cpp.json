{ // @author josuerom
	"#ifdef ONLINE_JUDGE": {
		"prefix": "testing",
		"body": [
			"#ifndef ONLINE_JUDGE",
      	"\tfreopen(\"test/$1input.txt\", \"r\", stdin);",
      	"\tfreopen(\"test/$1output.txt\", \"w\", stdout);",
   		"#endif$1"
		]
	},

	"ios::sync_with_stdio(false); cin.tie(nullptr); cout.tie(nullptr);": {
		"prefix": "ioo",
		"body": [
			"ios::sync_with_stdio(false); cin.tie(nullptr); cout.tie(nullptr);$1"
		]
	},

	"#pragma GCC optimize": {
		"prefix": "p",
		"body": [
			"#pragma GCC optimize(\"03,unroll-loops\")$1"
		]
	},

	"DocC++": {
		"prefix": "doc",
		"body": [
			"/*****************************************************",
			"* @AUTHOR:                 JOSUEROM                  *",
			"* @INSTITUTE: MINUTE OF GOD UNIVERSITY OF COLOMBIA   *",
			"* @DATE:                $1/11/22 $2               *",
			"******************************************************/\n$3"
		]
	},

	"return": {
		"prefix": "re",
		"body": [
			"return$1;"
		]
	},

	"line break": {
		"prefix": "n",
		"body": [
			"\"\\n\"$1"
		]
	},

	"getline() for char[]": {
		"prefix": "getline",
		"body": [
			"cin.getline($1, ${2:size}, '\\n');"
		]
	},

	"for (int i = 0; i < n; i++)": {
		"prefix": "fori",
		"body": [
			"for (int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {",
			"}",
		]
	},

	"for (auto $e : vec)": {
		"prefix": "fore",
		"body": [
			"for (auto &e : ${vector}) {",
			"}",
		]
	},

	"#include <bits/stdc++.h>": {
		"prefix": "in",
		"body": [
			"#include <bits/stdc++.h>\n",
			"#define SPEED_IO() ios::sync_with_stdio(false); cin.tie(nullptr); cout.tie(nullptr);",
			"#define TEST_CASE(a) while ((a)--) solve();",
			"#define ull unsigned long long",
			"#define ll long long",
			"#define ui unsigned int",
			"#define us unsigned short",
			"using namespace std;\n\n$1"
		]
	},

	"typedef": {
		"prefix": "typ",
		"body": [
			"typdef ${1:long long ll};"
		]
	},

	"#define": {
		"prefix": "de",
		"body": [
			"#define $1"
		]
	},

	"void solve() { body }": {
		"prefix": "solve",
		"body": [
			"void solve$1($2) {",
			"}"
		]
	},

	"function main": {
		"prefix": "m",
		"body": [
			"int main() {",
			"\t$1",
			"\treturn 0;",
			"}"
		]
	},

	"Plantilla c++ para competencias": {
		"prefix": "cpp_template_to_compete",
		"body": [
			"/**",
			" * @problem ${1:problemName} - CodeForces",
			" * @author josuerom",
			"*/",
			"//#pragma GCC optimize(\"03,unroll-loops\")",
			"#include <bits/stdc++.h>\n",
			"#define fastIO() ios::sync_with_stdio(false); cin.tie(nullptr);",
			"#define all(vec) (vec).begin(), (vec).end()",
			"#define rall(vec) (vec).rbegin(), (vec).rend()",
			"#define decimals(n) cout.setf(ios::fixed, ios::floatfield); cout.precision(n+1);",
			"#define sort(vec) sort((vec).begin(), (vec).end())",
			"#define sortreverse(vec) reverse((vec).begin(), (vec).end())",
			"#define fori(a, b, c) for(int (a) = (b); (a)<(c); (a)++)",
			"#define fore(e, vec) for (auto &(e): (vec))",
			"#define forr(i, vec) for(int i = (int)(vec).size()-1; i >= 0; i--)",
			"#define size(vec) (int)((vec).size())",
			"#define module(a, b, mod) ((((a) % (mod)) + ((b) % (mod))) % (mod))",
			"#define binarysearch(vec, key) sort(all(vec)); binary_search(all(vec), key);",
			"#define mcd(a, b) gcd(a, b)",
			"#define isordered(vec) is_heap(all(vec))",
			"#define read_array(vec) void template<typename T> void read(vector<T>& (vec)) { int n=(vec).size(); for(int i = 0; i < n; i++) { cin >> (vec)[i]; } }",
			"#define length(vec) sizeof(vec)/sizeof(vec[0])",
			"",
			"using namespace std;",
			"typedef unsigned long long int ull; //18^19",
			"typedef long long int ll; //9^18",
			"typedef unsigned int ui; //4^9",
			"typedef unsigned short us; //65^3",
			"",
			"void solve() {$5",
			"\t$3",
			"}",
			"",
			"int main() {",
			"\tfastIO();",
			"\t#ifndef ONLINE_JUDGE",
			"\t\tfreopen(\"input.txt\", \"r\", stdin);",
			"\t\tfreopen(\"output.txt\", \"w\", stdout);",
			"\t#endif",
			"\t${2:us} t=0;",
			"\tcin >> t;$4",
			"\twhile (t--) solve();",
			"\treturn 0;",
			"}",
		],
		"description": "Plantilla de C++ para competencias"
	}
}
