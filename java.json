			"}"
		],
	},

	"for iterator": {
		"prefix": "fori",
		"body": [
			"for (int ${1:i} = 0; ${1:i} < $2; ${1:i}++) {\n\t$3",
			"}"
		],
	},

	"for each": {
		"prefix": "fore",
		"body": [
			"for (${1:int} e : $2) {\n\t$3",
			"}"
		],
	},

	"switch": {
		"prefix": "sw",
		"body": [
			"switch ($1) {",
			"\tcase 1: $2;",
			"\t\tbreak;",
			"\tdefault:",
			"\t\tSystem.err.println('ERROR');",
			"}"
		],
	},

	"Ternary operator": {
		"prefix": "oter",
		"body": [
			"${1:boolean name} = (${2:condition}) ? $3 : $4;"
		],
	},

	"Object creation": {
		"prefix": "obj",
		"body": [
