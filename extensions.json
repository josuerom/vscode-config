// Presento las únicas extensiones que manejo dentro de Visual Studio Code
{
   "listOfExtensions": [
      {
         "extesionName": "Error Lens",
         "author": "Alexander",
         "descripcion":  "Susbraya e indica las líneas donde haya errores"
      },
      {
         "extesionName": "IntelliCode",
         "author": "Microsoft",
         "descripcion":  "Entrega de sugerencias rápidas para múltiples lenguajes y contiene inteligencia artificial"
      },
      {
         "extesionName": "Live Server",
         "author": "Ritwick Dey",
         "descripcion":  "Permite simular un servidor local en vivo para solo trabajar con HTML revisando sus cambios instantaneos"
      },
      {
         "extesionName": "Bearded Icons",
         "author": "BeardedBear",
         "descripcion":  "Añade iconos para directorios y archivos al SideBar o árbol de archivos"
      },
      {
         "extesionName": "Settings Sync",
         "author": "Shan Khan",
         "descripcion":  "Permite realizar copias de seguridad de toda la configuración de VSCode y guardarlas en la nube"
      },
      {
         "extesionName": "Gruvbox Glass",   
         "author": "Jack Paget",
         "descripcion":  "Complemento para tener un tema elegante como también un buen resaltado de sintaxis coloreado oscuro"
      },
      {
         "extesionName": "Auto Rename tag",   
         "author": "Jun Han",
         "descripcion":  "Complemento que permite realizar un renombrado de etiqueta inicial y final del archivo HTML"
      },
      {
         "extesionName": "Auto Close Tag",   
         "author": "Jun Han",
         "descripcion":  "Complemento de autocompletado instantaneo de etiquetas de apertura y cierre en HTML"
      },
      {
         "extesionName": "Trailing Space",
         "author": "Shardul Mahadik",
         "descripcion":  "Resalta con color rojo, las líneas que contenga espacios en blanco"
      },
      {
         "extesionName": "Todo Tree",
         "author": "Gruntfuggly",
         "descripcion":  "Esta enfocada para asignarnos tareas, también para dejar recordatorios dentro del código fuente que realizamos que son comentarios resaltados"
      },
      {
         "extesionName": "Markdown All in One",
         "author": "Yu Zhang",
         "descripcion":  "Permite en los archivos .md (markdown) escribir a la velocidad de la luz brindando una variedad de atajos para todo lo que contiene"
      },
      {
         "extesionName": "CodeTime",
         "author": "Software",
         "descripcion":  "Permite trabajar bajo con un cronometroen marcha, temporizador o tiempo libre, es de mucha utilidad"
      },
      {
         "extesionName": "Vibrancy Continued",
         "author": "illixion",
         "descripcion":  "Fondo con transparente para todo el editor de código"
      }
   ]
}
