{ // @author: josuerom
	"read int": {
		"prefix": "ri",
		"body": [
			"int(input())"
		],
	},
  "read str": {
		"prefix": "rs",
		"body": [
			"input("")"
		],
	},
  "read decimal": {
		"prefix": "rd",
		"body": [
			"float(input())"
		],
	},
  "read all line": {
		"prefix": "rd",
		"body": [
			"s = input().split(" ")"
		],
	},
  "read list int": {
		"prefix": "rli",
		"body": [
			"$1 = map(${2:int}, input().split(" "))"
		],
	},
  "read char array": {
		"prefix": "rac",
		"body": [
			"$1 = map(${2:int}, input().split(""))"
		],
	},
	"print()": {
		"prefix": "pp",
		"body": [
			"print($1)"
		],
	},
	"if": {
		"prefix": "if",
		"body": [
			"if $1:",
			"\t$2"
		],
	},
	"ifel": {
		"prefix": "ifel",
		"body": [
			"if $1:",
			"\t",
			"else $2:",
			"\t"
		],
	},
	"fori": {
		"prefix": "for",
		"body": [
			"for $1 in $2:",
			"\t"
		],
	},
	"while": {
		"prefix": "wh",
		"body": [
			"while $1:",
			"\t$2"
		],
	},
	"test cases": {
		"prefix": "tt",
		"body": [
			"tt = int(input())$1"
		],
	},
	"complexity": {
		"prefix": "com",
		"body": [
			"#   author: josuerom - complexity: O($1)",
		],
	},
	"@PythonDocs": {
		"prefix": "author",
		"body": [
			"#   author: josuerom - created: ${CURRENT_DATE}/${CURRENT_MONTH}/${CURRENT_YEAR_SHORT} ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}",
		],
	},
	"template 1 cp": {
		"prefix": "tem1",
		"body": [
			"#   author: josuerom - created: ${CURRENT_DATE}/${CURRENT_MONTH}/${CURRENT_YEAR_SHORT} ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}",
			"",
      "def solve(self):",
      "\t$1",
      "",
      "if __name__ == '__main__':",
      "\ttt = int(input())",
      "\twhile tt > 0:",
      "\t\tsolve()",
      "\t\ttt -= 1",
		],
	},
	"template 2 free": {
		"prefix": "tem2",
		"body": [
			"#   author: josuerom - created: ${CURRENT_DATE}/${CURRENT_MONTH}/${CURRENT_YEAR_SHORT} ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}",
			"$1"
		],
	},
	"def": {
		"prefix": "def",
		"body": [
			"def $1():",
			"\t$2",
		],
	},
	"def solve()": {
		"prefix": "fsol",
		"body": [
			"def solve(self):",
			"\t$1",
		],
	},
	"function main": {
		"prefix": "fm",
		"body": [
			"if __name__ == '__main__':",
			"\tsolve()"
		],
	},
}
