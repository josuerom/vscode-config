{
  // @author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "explorer.confirmDelete": false,
  "debug.onTaskErrors": "debugAnyway",
  "breadcrumbs.enabled": false,
  "redhat.telemetry.enabled": false,
  "window.commandCenter": true,
  "window.menuBarVisibility": "compact",
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
    "source": "PowerShell",
    "icon": "terminal-powershell"
    },
    "Command Prompt": {
    "path": [
    "${env:windir}\\Sysnative\\cmd.exe",
    "${env:windir}\\System32\\cmd.exe"
    ],
    "args": [],
    "icon": "terminal-cmd"
    }
  },
  "java.configuration.runtimes": [
    {
    "name": "JavaSE-21",
    "path": "d:\\compilers\\openjdk\\",
    "default": true
    }
  ],
  "[java]": {
    // "editor.formatOnSave": true,
    // "editor.formatOnPaste": true,
    // "editor.defaultFormatter": "redhat.java"
  },
  "[cpp]": {
    // "editor.formatOnPaste": true,
    // "editor.formatOnSave": true,
    // "editor.defaultFormatter": "redhat.java"
  },
  "[python]": {
    // "editor.formatOnSave": true,
    // "editor.formatOnPaste": true,
    // "editor.defaultFormatter": "ms-python.autopep8",
  },
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.fontFamily": "JetBrains Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.showRunCommandInEditorContextMenu": false,
  "code-runner.preserveFocus": false,
  "code-runner.clearPreviousOutput": true,
  "code-runner.cwd": "d:\\workspace\\bin",
  "code-runner.executorMap": {
    // compile and execute C++17 program, with manual entry
    "cpp": "cls && cd $dir && g++ $fileName -o d:\\workspace\\bin\\sol.exe -std=c++17 -DLOCAL && d:\\workspace\\bin\\sol.exe",
  
    // // compile and execute C++17 program, with input per file
    // "cpp": "cls && cd $dir && g++ $fileName -o d:\\workspace\\bin\\sol.exe -std=c++17 -DLOCAL && d:\\workspace\\bin\\sol.exe < ..\\samples\\in1",

    // // compile and execute C++20 program, with input per file and output per file
    // "cpp": "cls && cd $dir && g++ $fileName -o d:\\workspace\\bin\\sol.exe -std=c++20 -DLOCAL && d:\\workspace\\bin\\sol.exe < ..\\samples\\input.in > ..\\samples\\output.out",

    // // compile and run C++11 program for RPC, with input per file
    // "cpp": "cls && cd $dir && g++ $fileName -o $fileNameWithoutExt -std=c++11 -Wall -O2 -DLOCAL && $fileNameWithoutExt < in1",
    
    // // compile and run java version = 8 program, with manual entry
    // "java": "cls && cd $dir && javac -d d:\\workspace\\bin $fileName && java -cp d:\\workspace\\bin $fileNameWithoutExt",
    
    // // rerun binary file .class java version = 8
    // "rerun_java": "cls && java -cp d:\\workspace\\bin $fileNameWithoutExt",

    // compile and run java programs versions greater than > 8, with manual entry
    "java": "cls && cd $dir && java $fileName",
    
    "rerun_class": "cls && cd $dir && java $fileName < ..\\samples\\in1",
    "rerun_sol": "cls && d:\\workspace\\bin\\sol.exe",

    "python": "cls && cd $dir && python3 -OO -S -B $fileName",
    "javascript": "cls && cd $dir && node $fileName",
    "typescript": "cls && cd $dir && node $fileName",
  },
  // "workbench.colorTheme": "Default Dark Modern",
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "symbols",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.startupEditor": "none",
  "workbench.sideBar.location": "right",
  "workbench.statusBar.visible": true,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "single",
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  // "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "editor.accessibilitySupport": "off",
  "editor.hover.sticky": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "cph.general.menuChoices": "cpp java python",
  "cph.general.saveLocation": "d:\\workspace\\bin",
  "cph.language.cpp.Args": "-std=c++17 -DONLINE_JUDGE",
  "cph.language.cpp.SubmissionCompiler": "GNU G++17 9.2.0 (64 bit, msys 2)",
  "cph.language.java.SubmissionCompiler": "Java 1.8.0_241",
  "cph.language.python.SubmissionCompiler": "PyPy 3.9.10 (7.3.9, 64bit)",
  "cph.general.timeOut": 1000,
  "cph.general.autoShowJudge": false,
  "symbols.hidesExplorerArrows": false,
  "editor.rulers": [90],
  "security.workspace.trust.untrustedFiles": "open"
}
