{ //@author: josuerom
  "workbench.iconTheme": "material-icon-theme",
  "editor.fontFamily": "'Cascadia Code', 'JetBrains Mono', 'UbuntuMono NF', monospace",
  "terminal.integrated.gpuAcceleration": "off",
  "security.workspace.trust.untrustedFiles": "open",
  "editor.fontSize": 14.8,
  "editor.fontWeight": "373",
  "extensions.ignoreRecommendations": true,
  "workbench.editor.enablePreview": false,
  "editor.fontLigatures": true,
  "workbench.startupEditor": "none",
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "files.autoSave": "onFocusChange",
  "editor.wordWrap": "on",
  "diffEditor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "workbench.layoutControl.enabled": false,
  "window.menuBarVisibility": "compact",
  "editor.suggestSelection": "first",
  "terminal.integrated.cursorStyle": "line",
  "debug.terminal.clearBeforeReusing": true,
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "explorer.confirmDelete": false,
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "GitBash": {
      "path": "D:\\Program Files\\Git\\bin\\bash.exe",
      "icon": "terminal-bash",
      "color": "terminal.ansiGreen"
    }
  },
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.fontFamily": "'JetBrains Mono'",
  "terminal.integrated.fontSize": 13.8,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.executorMap": {
    "cpp": "cls && cd $dir && g++ $fileName -o sol.exe -std=c++20 -O2 -Wall -Wextra -Wl,--stack=256000000 -pedantic -Wshadow -Weffc++ -Wfloat-equal -Wconversion -Djosuerom -Wformat=2 -Wformat-signedness -Wvla -Wduplicated-cond -Wlogical-op -Wredundant-decls -ggdb3 -D_GLIBCXX_DEBUG -D_GLIBCXX_DEBUG_PEDANTIC -D_FORTIFY_SOURCE=2 -fsanitize=address -fsanitize=undefined -fdiagnostics-color=always && sol.exe",
    // "cpp": "cls && cd $dir && g++ $fileName -o sol.exe -std=c++11 -Wall -Wextra -pedantic -Weffc++ -Wconversion -Djosuerom -fdiagnostics-color=always && sol.exe",
    "java": "cls && cd $dir && javac -source 1.8 -target 1.8 -g:none -Xlint:deprecation $fileName && java -Xmx256M -Xss64M -DDEBUG=true -XX:-UseStringDeduplication -verbose:gc $fileNameWithoutExt",
    "python": "cls && cd $dir && python3 $fileName",
    "javascript": "cls && cd $dir && node $dir/$fileName",
    "typescript": "cls && cd $dir && node $dir/$fileName",
    "kotlin": "cls && cd $dir && kotlin -u $fileName"
  },
  "code-runner.temporaryFileName": "fileTempError",
  //"workbench.statusBar.visible": false,
  //"workbench.activityBar.visible": false,
  "window.commandCenter": true,
  "workbench.sideBar.location": "right",
  "workbench.editor.showTabs": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": false,
  "editor.glyphMargin": false,
  "debug.onTaskErrors": "debugAnyway",
  "breadcrumbs.enabled": false,
  "java.configuration.runtimes": [
    {
      "name": "OpenJDK-19",
      "path": "D:\\Program Files\\Compilers\\Java-19.0.2\\bin",
      "default": true
    }
  ],
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "redhat.telemetry.enabled": false,
  "git.openRepositoryInParentFolders": "never",
}
