{ // @author: josuerom
  "files.autoSave": "onFocusChange",
  "diffEditor.wordWrap": "on",
  "debug.terminal.clearBeforeReusing": true,
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.untrustedFiles": "open",
  "redhat.telemetry.enabled": false,
  "explorer.confirmDelete": false,

  "window.commandCenter": true,
  "window.menuBarVisibility": "compact",

  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },

  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "GitBash": {
      "path": "D:\\Program Files\\Git\\bin\\bash.exe",
      "icon": "terminal-bash",
      "color": "terminal.ansiGreen"
    }
  },

  "java.configuration.runtimes": [
    {
      "name": "JavaSE-19",
      "path": "D:\\Program Files\\Compilers\\Jdk-19.0.1\\",
      "default": true
    }
  ],

  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.fontFamily": "JetBrains Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",

  "code-runner.temporaryFileName": "fileTempError",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.clearPreviousOutput": true,
  "code-runner.defaultLanguage": "cpp java",
  "code-runner.fileDirectoryAsCwd": true,
  "code-runner.executorMap": {
    "cpp": "cls && cd $dir && g++ $fileName -o d:\\workspace\\build\\vs-sol.exe -march=native -Wall -Wextra -Wpedantic -Wshadow -Wvla -Djosuerom",
    "java": "cls && cd $dir && javac -d d:\\workspace\\build $fileName",
    "run c++": "cls && d: && d:\\workspace\\build\\vs-sol.exe",
    "run java": "cls && d: && cd d:\\workspace\\build && java -Xmx512M -Xss64M -DONLINE_JUDGE=true $fileNameWithoutExt",
    "run c++ input file": "cls && d: && d:\\workspace\\build\\vs-sol.exe < d:\\workspace\\sample\\input",
    "run java input file": "cls && d: && cd d:\\workspace\\build && java -Xmx512M -Xss64M -DONLINE_JUDGE=true $fileNameWithoutExt < d:\\workspace\\sample\\input",
    "open input file": "cls && d: && notepad d:\\workspace\\sample\\input",
    "python": "cls && cd $dir && python $fileName",
    "javascript": "cls && cd $dir && node $fileName",
    "typescript": "cls && cd $dir && node $fileName",
  },

  // "workbench.statusBar.visible": false,
  // "workbench.activityBar.visible": false,
  "workbench.colorTheme": "Palenight Operator",
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.layoutControl.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": false,

  "editor.fontFamily": "'Cascadia Code', 'JetBrains Mono', 'UbuntuMono Nerd Font'",
  "editor.fontSize": 13.8,
  "editor.fontWeight": "373",
  "editor.fontLigatures": true,
  "editor.tabCompletion": "on",
  "editor.tabSize": 3,
  "editor.padding.bottom": 0,
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.cursorBlinking": "expand",
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "debug.onTaskErrors": "debugAnyway",
  "breadcrumbs.enabled": false,

  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",

  //"cph.general.defaultLanguage": "java",
  "cph.general.menuChoices": "cpp java python",
  "cph.language.java.SubmissionCompiler": "Java 1.8.0_241",
  "cph.language.cpp.SubmissionCompiler": "GNU G++17 7.3.0",
  "cph.language.python.SubmissionCompiler": "Python 3.7.2",
  "cph.general.saveLocation": "D:\\Workspace\\build",
  //"cph.general.defaultLanguageTemplateFileLocation": C:\\Users\\jr3\\templates\\temp-java",
  "cph.language.cpp.Args": "-march=native -Wall -Wextra -Wpedantic -Wshadow -Wvla -Djosuerom",
  "cph.language.java.Args": "-Xmx512M -Xss64M -DONLINE_JUDGE=true",
}
